# Neural Pac-Man Runner — Vercel Edition
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables

# Vercel Postgres (required)
# From: Vercel Dashboard → Storage → Create → Postgres → .env.local
POSTGRES_URL=postgres://user:pass@host:5432/db?sslmode=require

# Vercel Blob (required for face snapshots)
# From: Vercel Dashboard → Storage → Create → Blob → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXX
